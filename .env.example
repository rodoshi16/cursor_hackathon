# ---------------------------------------------------------------------------
# Auth0 — gate the logged-in pages behind a real login.
# Leave blank to keep the app fully open (demo mode).
# ---------------------------------------------------------------------------
# A long random string (>=32 chars). Generate with: openssl rand -hex 32
AUTH0_SECRET=
# The URL this app runs at. Use http://localhost:3000 locally.
AUTH0_BASE_URL=http://localhost:3000
# Your Auth0 tenant domain, prefixed with https://
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Google (Gmail + Calendar) — needed to read recruiter emails and create events
# in Google Calendar. Leave blank to use demo data.
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ---------------------------------------------------------------------------
# Microsoft (Outlook + Outlook Calendar) — same idea, optional.
# ---------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# ElevenLabs — voice briefings and the Conversational AI agent on /agent.
# Leave blank to see the fallback "script that would be spoken".
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_AGENT_ID=

# ---------------------------------------------------------------------------
# Demo mode — when true, all providers fall back to mock data.
# Set false to require connected accounts.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_MODE=true
